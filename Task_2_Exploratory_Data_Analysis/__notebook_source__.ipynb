import os
os.listdir('/kaggle/input/datasets/shalinim27/dataset-cleaned')


import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns


df = pd.read_excel('/kaggle/input/datasets/shalinim27/dataset-cleaned/cleaned dataset.xlsx')


df.describe()


plt.figure(figsize=(8,5))
df['TotalPrice'].hist(bins=10)
plt.title('Distribution of Total Values')
plt.xlabel('Tolal Price')
plt.ylabel('Total Orders')
plt.show()





sns.boxplot(df['TotalPrice'])





Q1 = df['TotalPrice'].quantile(0.25)
Q3 = df['TotalPrice'].quantile(0.75)
IQR = Q3-Q1
lower = Q1 - 1.5*IQR
upper = Q3 + 1.5*IQR
outliers = df[(df['TotalPrice']<lower) | (df['TotalPrice'] > upper)]
outliers


len(outliers)



df['Date'] = pd.to_datetime(df['Date'])


monthly_sales = df.groupby(df['Date'].dt.to_period('M'))['TotalPrice'].sum()
monthly_sales


monthly_sales.plot(figsize=(10,5))
plt.title('Monthly Sales Trend')
plt.xlabel('Month')
plt.ylabel('Sales')
plt.show()





df['Quantity'].value_counts().sort_index()


sns.countplot(x='Quantity',data=df)
plt.show()





corr = df[['Quantity','UnitPrice','ItemsInCart','TotalPrice']].corr()
corr


sns.heatmap(corr,annot=True)
plt.show()






